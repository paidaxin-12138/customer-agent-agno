# Customer-Agent 环境变量配置
# 复制此文件为 .env 并填入实际值

# LLM 配置
LLM_MODEL_NAME=qwen3.6-flash
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MAX_TOKENS=256
LLM_TEMPERATURE=0.5

# Embedder 配置
EMBEDDER_MODEL_NAME=text-embedding-v4
EMBEDDER_API_KEY=your-api-key-here
EMBEDDER_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 知识库配置
KNOWLEDGE_CONTENTS_DB_PATH=./Agent/CustomerAgent/knowledge
KNOWLEDGE_VECTOR_DB_PATH=./vector_db

# 数据库配置
DB_PATH=./data/customer_agent.db

# 拼多多开放平台（可选）
PDD_ENABLED=false
PDD_CLIENT_ID=your-client-id-here
PDD_CLIENT_SECRET=your-client-secret-here
PDD_ACCESS_TOKEN=your-access-token-here

# 营业时间
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=23:00

# 日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO
